# LM Studio Local LLM Inference (Required)
# Download LM Studio from https://lmstudio.ai
# Recommended models:
#   - google/gemma-4-12b (12B, best quality)
#   - Qwen-2.5-7B-Instruct (7B, good balance)
#   - Llama-2-7B-Chat (7B, alternative)
# Start the local server: LM Studio → Local Server → Start
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL_NAME=google/gemma-4-12b
LLM_TEMPERATURE=0.2

# Embeddings
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Vector Store
CHROMA_PERSIST_DIR=./data/processed/chroma_db

# Chunking & Retrieval
CHUNK_SIZE=700
CHUNK_OVERLAP=100
RETRIEVAL_K=8
RERANK_K=3

# Confidence Gating
CONFIDENCE_THRESHOLD=0.4
MIN_SIMILARITY_SCORE=0.3

# Logging
LOG_LEVEL=INFO
